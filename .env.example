 # ============================================
# ENVIRONMENT VARIABLES - متغیرهای محیطی
# ============================================

# App Configuration
APP_NAME="پلتفرم نوبت‌دهی هوشمند"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://booking-platform.ir
APP_TIMEZONE=Asia/Tehran
APP_LOCALE=fa

# API Configuration
API_URL=https://api.booking-platform.ir
API_VERSION=v1
API_TIMEOUT=30
API_RETRY_COUNT=3

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=booking_platform
DB_USERNAME=root
DB_PASSWORD=

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@booking-platform.ir
MAIL_FROM_NAME="پلتفرم نوبت‌دهی"

# SMS Configuration
SMS_PROVIDER=kavenegar
SMS_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SMS_SENDER_NUMBER=100020000

# Payment Gateways
ZARINPAL_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ZARINPAL_SANDBOX=true

IDPAY_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
IDPAY_SANDBOX=true

NEXTPAY_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXTPAY_SANDBOX=true

PAYIR_API_KEY=xxxxxxxxxxxxxxxxxxxx
PAYIR_SANDBOX=true

ZIBAL_MERCHANT_ID=zibal
ZIBAL_SANDBOX=true

VANDAR_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VANDAR_SANDBOX=true

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key
JWT_TTL=7200
JWT_REFRESH_TTL=604800

# CORS Configuration
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Rate Limiting
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=60

# Cache Configuration
CACHE_DRIVER=redis
CACHE_PREFIX=booking_
CACHE_TTL=3600

# Session Configuration
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_COOKIE_NAME=booking_session

# PWA Configuration
PWA_ENABLED=true
PWA_CACHE_NAME=booking-platform-v1
PWA_OFFLINE_PAGE=/offline.html

# Feature Flags
FEATURE_REVERSE_MARKET=true
FEATURE_GROUP_BOOKING=true
FEATURE_LOYALTY_PROGRAM=true
FEATURE_REFERRAL_PROGRAM=true
FEATURE_RECURRING_BOOKING=true
FEATURE_WAITING_LIST=true

# Social Media
SOCIAL_INSTAGRAM=https://instagram.com/bookingplatform
SOCIAL_TELEGRAM=https://t.me/bookingplatform
SOCIAL_TWITTER=https://twitter.com/bookingplatform
SOCIAL_LINKEDIN=https://linkedin.com/company/bookingplatform

# SEO
SEO_SITE_URL=https://booking-platform.ir
SEO_SITE_NAME="پلتفرم نوبت‌دهی هوشمند"
SEO_TWITTER_CARD=summary_large_image
SEO_DEFAULT_IMAGE=/assets/images/og-image.jpg

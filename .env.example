# هرگز این فایل را با مقادیر واقعی commit نکنید — فقط الگو است.

# Database
DATABASE_URL="postgresql://booking:booking_dev_password@localhost:5432/booking_platform"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# App
PORT=3001
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# Payment Gateway (Zarinpal - sandbox)
ZARINPAL_MERCHANT_ID=""
ZARINPAL_SANDBOX=true

# SMS Provider (OTP)
SMS_PROVIDER_API_KEY=""

# Object Storage (تصاویر/مدارک)
STORAGE_BUCKET_URL=""
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""

# قبل از وصل شدن پیامک واقعی: اگر true باشه، کد OTP مستقیم در پاسخ
# API برمی‌گرده (فیلد debugCode) تا فرانت بتونه همون‌جا نشونش بده.
# صرف‌نظر از این مقدار، در NODE_ENV=production همیشه غیرفعاله.
# بعد از وصل کردن provider واقعی پیامک، این رو false کنید یا حذفش کنید.
OTP_DEBUG_EXPOSE=true

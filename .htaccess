 # ============================================
# HTACCESS - تنظیمات سرور Apache
# ============================================

# فعال کردن Rewrite Engine
RewriteEngine On

# تنظیم charset پیش‌فرض
AddDefaultCharset UTF-8

# تنظیم زبان پیش‌فرض
DefaultLanguage fa-IR

# Redirect به HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Redirect به نسخه بدون www
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# SPA Routing - تمام درخواست‌ها به index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]

# کش کردن فایل‌های استاتیک
<FilesMatch "\.(css|js|jpg|jpeg|png|gif|ico|svg|woff|woff2|ttf|eot)$">
    Header set Cache-Control "max-age=2592000, public"
</FilesMatch>

# کش کردن فایل‌های HTML
<FilesMatch "\.(html|htm)$">
    Header set Cache-Control "max-age=3600, must-revalidate"
</FilesMatch>

# جلوگیری از کش کردن فایل‌های حساس
<FilesMatch "\.(env|json|xml|sql)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
</FilesMatch>

# Gzip Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# امنیت - جلوگیری از لیست شدن دایرکتوری‌ها
Options -Indexes

# امنیت - محافظت از فایل‌های حساس
<FilesMatch "^\.(env|gitignore|htaccess)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# امنیت - جلوگیری از XSS
Header set X-XSS-Protection "1; mode=block"

# امنیت - جلوگیری از MIME sniffing
Header set X-Content-Type-Options "nosniff"

# امنیت - Frame Options
Header set X-Frame-Options "DENY"

# امنیت - Content Security Policy (CSP)
Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https:;"

# CORS
Header set Access-Control-Allow-Origin "*"
Header set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
Header set Access-Control-Allow-Headers "Content-Type, Authorization"

# Error pages
ErrorDocument 400 /400.html
ErrorDocument 401 /401.html
ErrorDocument 403 /403.html
ErrorDocument 404 /404.html
ErrorDocument 500 /500.html
